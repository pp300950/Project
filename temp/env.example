# Smart Shoe Monitor — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับระบบของคุณ
# (อย่า commit ไฟล์ .env ขึ้น Git!)

# ── Database ──────────────────────────────────────────────
# Connection string จาก Supabase → Settings → Database → URI
# แทน [YOUR-PASSWORD] ด้วย password ที่ตั้งไว้
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── JWT Auth ───────────────────────────────────────────────
# สุ่มได้ด้วย: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_string_in_production

# ── Admin login ────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
